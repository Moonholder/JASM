<ContentDialog
    x:Class="GIMI_ModManager.WinUI.Views.Dialogs.GameBananaInstallTargetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:l="using:WinUI3Localizer"
    Title="Select Install Target"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Width="320">
        <TextBlock x:Name="PromptTextBlock" TextWrapping="Wrap" />
        <HyperlinkButton x:Name="StrongMatchBtn" 
            Margin="0,4,0,4" 
            Click="StrongMatchBtn_Click" />
        <AutoSuggestBox x:Name="SearchBox" 
            Margin="0,8,0,0" 
            TextChanged="SearchBox_TextChanged" >
            <AutoSuggestBox.QueryIcon>
                <SymbolIcon Symbol="Find"/>
            </AutoSuggestBox.QueryIcon>
        </AutoSuggestBox>
        <ListView x:Name="TargetListView" 
            MaxHeight="300"
            Margin="0,8,0,0" 
            SelectionMode="Single"
            DisplayMemberPath="Item2" />
    </StackPanel>
</ContentDialog>
