<Page
    x:Class="GIMI_ModManager.WinUI.Views.GameBananaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:GIMI_ModManager.WinUI.Helpers.Xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:GIMI_ModManager.Core.Services.GameBanana.Models"
    xmlns:vm="using:GIMI_ModManager.WinUI.ViewModels"
    xmlns:tkcontrols="using:CommunityToolkit.WinUI.Controls"
    xmlns:l="using:WinUI3Localizer"
    x:Name="PageRoot"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="GbCardBackground" Color="#15FFFFFF" />
                    <!-- Opaque fallback for WebView to stop DirectComposition hole punch -->
                    <SolidColorBrush x:Key="GbWebViewBackground" Color="#282828" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="GbCardBackground" Color="#80FFFFFF" />
                    <SolidColorBrush x:Key="GbWebViewBackground" Color="#F3F3F3" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <helpers:IntToVisibilityInverter x:Key="IntToVisibilityInverter" />
            <helpers:BoolInverterConverter x:Key="BoolInverterConverter" />
            <DataTemplate x:Key="ModCardTemplate" x:DataType="vm:GbModDisplayItem">
                <Grid
                    Height="240"
                    Margin="6"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerEntered="ModCard_PointerEntered"
                    PointerExited="ModCard_PointerExited">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Thumbnail  -->
                    <Grid Grid.Row="0" CornerRadius="8,8,0,0">
                        <!-- Fallback icon -->
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="36"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <Image
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{x:Bind ThumbnailImage, Mode=OneWay}"
                            Stretch="UniformToFill" />
                        
                        <!--  NSFW blur overlay  -->
                        <Grid CornerRadius="8,8,0,0" Visibility="{x:Bind NsfwLabelVisibility, Mode=OneWay}">
                            <Image
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Source="{x:Bind BlurredThumbnailImage, Mode=OneWay}"
                                Stretch="UniformToFill" />
                            <Border Background="#601A1A2E" />
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    FontSize="24"
                                    Foreground="#AAFFFFFF"
                                    Glyph="&#xE72E;" />
                                <Border
                                    Padding="8,3,8,3"
                                    HorizontalAlignment="Center"
                                    Background="#CCFF4444"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="BLURRED" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Top-Right Badges -->
                        <StackPanel
                            Margin="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Spacing="6">
                            <!-- NSFW Tag (Always visible if IsNsfw is true) -->
                            <Border
                                Padding="5,2"
                                Background="#D0E81123"
                                CornerRadius="4"
                                Visibility="{x:Bind IsNsfwVisible, Mode=OneWay}">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="NSFW" />
                            </Border>

                            <!-- Type Badge Overlay (Tool, WIP, Request, etc.) -->
                            <Border
                                Padding="5,2"
                                Background="#D0101010"
                                CornerRadius="4"
                                Visibility="{x:Bind TypeLabelVisibility, Mode=OneWay}">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Text="{x:Bind TypeLabel, Mode=OneWay}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!--  Info Layout  -->
                    <Grid Grid.Row="1" Padding="12,12,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Title max 2 lines -->
                            <RowDefinition Height="*" />    <!-- Flexible spacer -->
                            <RowDefinition Height="Auto" /> <!-- Meta info -->
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock
                            Grid.Row="0"
                            FontSize="13"
                            LineHeight="18"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            MaxLines="2"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />

                        <!-- Bottom container for Author + Stats -->
                        <Grid Grid.Row="2" VerticalAlignment="Bottom">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Author & Date -->
                                <RowDefinition Height="8" />    <!-- Spacing -->
                                <RowDefinition Height="Auto" /> <!-- Stats -->
                            </Grid.RowDefinitions>

                            <!-- Author & Date -->
                            <Grid Grid.Row="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <PersonPicture
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,6,0"
                                    DisplayName="{x:Bind AuthorName}"
                                    ProfilePicture="{x:Bind AuthorAvatarImage, Mode=OneWay}" />
                                
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind AuthorName}"
                                    TextTrimming="CharacterEllipsis" />
                                    
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind FormattedDate}" />
                            </Grid>

                            <!-- Statistics -->
                            <StackPanel
                                Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="14"
                                Opacity="0.8">
                                <!-- Likes -->
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon FontSize="10" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE006;" />
                                    <TextBlock FontSize="10" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind FormattedLikes}" />
                                </StackPanel>
                                <!-- Downloads -->
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon FontSize="10" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE7B3;" />
                                    <TextBlock FontSize="10" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind FormattedDownloads}" />
                                </StackPanel>
                                <!-- Comments -->
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon FontSize="10" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE8F2;" />
                                    <TextBlock FontSize="10" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind FormattedComments}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <SplitView
        x:Name="DetailSplitView"
        DisplayMode="Overlay"
        IsPaneOpen="{x:Bind ViewModel.IsDetailPaneOpen, Mode=TwoWay}"
        OpenPaneLength="420"
        PaneBackground="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        PanePlacement="Right">

        <!--  Detail Pane  -->
        <SplitView.Pane>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Header with close button  -->
                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Padding="20,16,20,0">
                    <TextBlock
                        Margin="0,0,40,0"
                        MaxLines="2"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{x:Bind ViewModel.SelectedModName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{x:Bind ViewModel.CloseDetailPaneCommand}">
                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                    </Button>
                </Grid>

                <!--  Loading  -->
                <ProgressRing
                    Grid.Row="1"
                    Width="36"
                    Height="36"
                    Margin="0,0,12,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsDetailLoading, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsDetailLoading, Mode=OneWay}" />

                <!--  Detail content  -->
                <Grid
                    Grid.Row="1"
                    Padding="20,0,8,12"
                    Visibility="{x:Bind ViewModel.HasModDetail, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Author + Stats card  -->
                    <Grid
                        Grid.Row="0"
                        Margin="0,0,12,12"
                        Padding="14,12"
                        Background="{ThemeResource GbCardBackground}"
                        CornerRadius="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  Author  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <PersonPicture
                                        Width="36"
                                        Height="36"
                                        DisplayName="{x:Bind ViewModel.SelectedModAuthor, Mode=OneWay}"
                                        ProfilePicture="{x:Bind ViewModel.SelectedModAuthorAvatar, Mode=OneWay}" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.SelectedModAuthor, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.SelectedModDate, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Stats row  -->
                                <Grid
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Glyph="&#xE006;" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.SelectedModLikes, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Likes"
                                            l:Uids.Uid="/GameBananaPage/LikesLabel" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Glyph="&#xE7B3;" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind ViewModel.SelectedModViews, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Views"
                                            l:Uids.Uid="/GameBananaPage/ViewsLabel" />
                                    </StackPanel>
                                </Grid>
                            </Grid>

                    <!-- Tabs Segmented -->
                    <tkcontrols:Segmented
                        x:Name="DetailSegmented"
                        Grid.Row="1"
                        Margin="0,0,12,12"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0"
                        SelectionChanged="DetailSegmented_SelectionChanged">
                        <tkcontrols:SegmentedItem Content="Overview" l:Uids.Uid="/GameBananaPage/TabOverviewItem" />
                        <tkcontrols:SegmentedItem Content="Description" Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay}" l:Uids.Uid="/GameBananaPage/TabDescriptionItem" />
                        <tkcontrols:SegmentedItem Content="Updates" Visibility="{x:Bind ViewModel.HasUpdateLog, Mode=OneWay}" l:Uids.Uid="/GameBananaPage/TabUpdateLogItem" />
                    </tkcontrols:Segmented>

                    <!-- Tab 0: Overview -->
                    <ScrollViewer x:Name="TabOverview" Grid.Row="2" Padding="0,0,12,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12" Padding="0,0,0,20">
                            <!--  Preview images  -->
                            <!--  Preview images  -->
                            <ListView
                                x:Name="PreviewListView"
                                Height="200"
                                Margin="0,0,-12,0"
                                ContainerContentChanging="PreviewListView_ContainerContentChanging"
                                IsItemClickEnabled="True"
                                ItemClick="PreviewImage_ItemClick"
                                ItemsSource="{x:Bind ViewModel.PreviewImages, Mode=OneWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollMode="Enabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                SelectionMode="None"
                                Visibility="{x:Bind ViewModel.HasPreviewImages, Mode=OneWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,12,0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="MinWidth" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ListViewItemPresenter
                                                        ContentMargin="0"
                                                        PointerOverBackground="Transparent"
                                                        PressedBackground="Transparent"
                                                        SelectedBackground="Transparent" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GbPreviewImageItem">
                                        <Grid
                                            Width="300"
                                            Height="200"
                                            Background="#20808080"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            PointerEntered="PreviewImage_PointerEntered"
                                            PointerExited="PreviewImage_PointerExited">
                                            <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" />
                                            <Border Background="#40000000" Opacity="0">
                                                <FontIcon
                                                    FontSize="32"
                                                    Foreground="White"
                                                    Glyph="&#xE8A3;" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!--  Actions  -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.OpenInBrowserCommand}"
                                    Content="Open in Browser"
                                    l:Uids.Uid="/GameBananaPage/OpenInBrowserBtn" />
                            </Grid>

                            <!--  Files list  -->
                            <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}">
                                <TextBlock
                                    Margin="0,4,0,2"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="Downloadable Files"
                                    l:Uids.Uid="/GameBananaPage/DownloadableFilesHdr" />
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ModFiles, Mode=OneWay}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ModFileInfo">
                                            <Grid
                                                Margin="0,0,0,4"
                                                Padding="12,10"
                                                Background="{ThemeResource GbCardBackground}"
                                                CornerRadius="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel
                                                    Grid.Column="0"
                                                    Margin="0,0,8,0"
                                                    Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <TextBlock
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind FileName}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind FormattedVersion}"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,0,1" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        MaxLines="2"
                                                        Text="{x:Bind Description}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="Wrap" />
                                                    <StackPanel
                                                        Margin="0,2,0,0"
                                                        Orientation="Horizontal"
                                                        Spacing="12">
                                                        <TextBlock
                                                            FontSize="10"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Text="{x:Bind FormattedFileSize}" />
                                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                                            <FontIcon
                                                                FontSize="10"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Glyph="&#xE896;" />
                                                            <TextBlock
                                                                FontSize="10"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Text="{x:Bind FormattedDownloadCount}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Click="DownloadButton_Click"
                                                    IsEnabled="{x:Bind IsDownloading, Mode=OneWay, Converter={StaticResource BoolInverterConverter}}"
                                                    Style="{ThemeResource AccentButtonStyle}"
                                                    Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Download &amp; Install"
                                                    l:Uids.Uid="/GameBananaPage/DownloadBtn">
                                                    <FontIcon FontSize="14" Glyph="&#xE896;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tab 1: Description -->
                    <Border
                        x:Name="TabDescription"
                        Grid.Row="2"
                        Margin="0,0,12,0"
                        Padding="2"
                        Background="{ThemeResource GbWebViewBackground}"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <WebView2
                            x:Name="DescriptionWebView"
                            DefaultBackgroundColor="Transparent"
                            NavigationStarting="WebView_NavigationStarting" />
                    </Border>

                    <!-- Tab 2: Update Log -->
                    <Border
                        x:Name="TabUpdateLog"
                        Grid.Row="2"
                        Margin="0,0,12,0"
                        Padding="2"
                        Background="{ThemeResource GbWebViewBackground}"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <WebView2
                            x:Name="UpdateLogWebView"
                            DefaultBackgroundColor="Transparent"
                            NavigationStarting="WebView_NavigationStarting" />
                    </Border>
                </Grid>
            </Grid>
        </SplitView.Pane>

        <!--  Main content  -->
        <SplitView.Content>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CategoryColumn" Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Left: Categories  -->
                <Grid Grid.Column="0" Padding="0,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="12,8,0,8"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="分类"
                        l:Uids.Uid="/GameBananaPage/CategoriesHdr" />

                    <ProgressRing
                        Grid.Row="1"
                        Width="24"
                        Height="24"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        IsActive="{x:Bind ViewModel.IsCategoriesLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsCategoriesLoading, Mode=OneWay}" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Categories}"
                        SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                        SelectionChanged="CategoryList_SelectionChanged"
                        ContainerContentChanging="CategoryList_ContainerContentChanging"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:GbCategoryDisplayItem">
                                <Grid Padding="4,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!--  Icon fallback to FontIcon  -->
                                    <FontIcon
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Glyph="{x:Bind IconGlyph}" />
                                    <!--  Real Image  -->
                                    <Image
                                        Grid.Column="0"
                                        Width="24"
                                        Height="24"
                                        VerticalAlignment="Center"
                                        Source="{x:Bind IconImage, Mode=OneWay}"
                                        Stretch="UniformToFill" />
                                        
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="{x:Bind SectionFontWeight}"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis" />
                                        
                                    <!-- Play count badge -->
                                    <Border
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Padding="6,2"
                                        Background="#15FFFFFF"
                                        CornerRadius="4"
                                        Visibility="{x:Bind HasItemCountText}">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ItemCountText}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!--  Right: Mod list  -->
                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Top bar: Search and Sort and Filters  -->
                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <AutoSuggestBox
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            PlaceholderText="Search mods..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                            QuerySubmitted="{x:Bind ViewModel.OnSearchSubmitted}"
                            l:Uids.Uid="/GameBananaPage/SearchModBox" />

                        <ComboBox
                            Grid.Column="1"
                            Width="120"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.ModelFilterOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedModelFilterOption, Mode=TwoWay}" />

                        <ComboBox
                            Grid.Column="2"
                            Width="130"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.NsfwPolicyOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedNsfwPolicyOption, Mode=TwoWay}" />

                        <ComboBox
                            Grid.Column="3"
                            Width="130"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.SortOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}" />

                        <Button
                            Grid.Column="4"
                            VerticalAlignment="Center"
                            Style="{ThemeResource DefaultButtonStyle}"
                            ToolTipService.ToolTip="Download Manager"
                            l:Uids.Uid="/GameBananaPage/DownloadManagerBtn">
                            <Grid>
                                <FontIcon FontSize="16" Glyph="&#xE896;" />
                                <InfoBadge 
                                    Value="{x:Bind ViewModel.ActiveDownloadCount, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.HasActiveDownloads, Mode=OneWay}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-8,-12,0"/>
                            </Grid>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Grid Width="350">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                                Text="Download Queue"
                                                l:Uids.Uid="/GameBananaPage/DownloadQueueHdr" />
                                            <Button
                                                Grid.Column="1"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Command="{x:Bind ViewModel.ClearAllCompletedTasksCommand}"
                                                Content="Clear Completed"
                                                FontSize="12"
                                                l:Uids.Uid="/GameBananaPage/ClearCompletedBtn" />
                                        </Grid>

                                        <ListView
                                            Grid.Row="1"
                                            MaxHeight="400"
                                            ItemsSource="{x:Bind ViewModel.DownloadQueue}"
                                            SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="vm:GbDownloadTask">
                                                    <Grid Margin="0,4,0,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Margin="0,0,8,4"
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind FileInfo.FileName}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <StackPanel
                                                                Grid.Column="1"
                                                                VerticalAlignment="Top"
                                                                Orientation="Horizontal"
                                                                Spacing="4">
                                                                <!--  Retry button  -->
                                                                <Button
                                                                    Padding="4"
                                                                    Click="RetryDownloadTask_Click"
                                                                    ToolTipService.ToolTip="Retry Installation"
                                                                    Visibility="{x:Bind RetryVisibility, Mode=OneWay}"
                                                                    l:Uids.Uid="/GameBananaPage/RetryBtn">
                                                                    <FontIcon FontSize="10" Glyph="&#xE72C;" />
                                                                </Button>
                                                                <!--  Cancel button (visible during download)  -->
                                                                <Button
                                                                    Padding="4"
                                                                    Click="CancelDownloadTask_Click"
                                                                    ToolTipService.ToolTip="Cancel"
                                                                    Visibility="{x:Bind CancelVisibility, Mode=OneWay}"
                                                                    l:Uids.Uid="/GameBananaPage/CancelBtn">
                                                                    <FontIcon FontSize="10" Glyph="&#xE711;" />
                                                                </Button>
                                                                <!--  Remove button (visible after completion)  -->
                                                                <Button
                                                                    Padding="4"
                                                                    Click="RemoveDownloadTask_Click"
                                                                    ToolTipService.ToolTip="Remove"
                                                                    Visibility="{x:Bind RemoveVisibility, Mode=OneWay}"
                                                                    l:Uids.Uid="/GameBananaPage/RemoveBtn">
                                                                    <FontIcon FontSize="10" Glyph="&#xE74D;" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <ProgressBar
                                                            Grid.Row="1"
                                                            Margin="0,0,0,4"
                                                            IsIndeterminate="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolInverterConverter}}"
                                                            Maximum="100"
                                                            ShowError="{x:Bind IsError, Mode=OneWay}"
                                                            Value="{x:Bind ProgressPercentage, Mode=OneWay}" />

                                                        <TextBlock
                                                            Grid.Row="2"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind StatusMessage, Mode=OneWay}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>

                                            <!--  Empty state indicator  -->
                                            <ListView.Header>
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    FontStyle="Italic"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Text="No active tasks"
                                                    Visibility="{x:Bind ViewModel.DownloadQueue.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityInverter}}"
                                                    l:Uids.Uid="/GameBananaPage/EmptyQueueHdr" />
                                            </ListView.Header>
                                        </ListView>
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <!--  Error message  -->
                    <InfoBar
                        Grid.Row="1"
                        Margin="8,0,8,0"
                        VerticalAlignment="Top"
                        IsOpen="{x:Bind ViewModel.HasError, Mode=TwoWay}"
                        Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Severity="Error" />

                    <!--  Loading  -->
                    <ProgressRing
                        Grid.Row="1"
                        Width="48"
                        Height="48"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

                    <!--  Mod GridView: AdaptiveGridView fills width cleanly  -->
                    <controls:AdaptiveGridView
                        x:Name="ModsGridView"
                        Grid.Row="1"
                        Padding="4"
                        DesiredWidth="210"
                        IsItemClickEnabled="True"
                        ItemClick="ModsGridView_ItemClick"
                        ItemHeight="270"
                        ItemTemplate="{StaticResource ModCardTemplate}"
                        ItemsSource="{x:Bind ViewModel.Mods}"
                        Loaded="ModsGridView_Loaded"
                        SelectionMode="None"
                        StretchContentForSingleRow="False"
                        Visibility="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}">
                        <controls:AdaptiveGridView.Footer>
                            <ProgressRing
                                Width="28"
                                Height="28"
                                Margin="0,12,0,24"
                                HorizontalAlignment="Center"
                                IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
                        </controls:AdaptiveGridView.Footer>
                    </controls:AdaptiveGridView>
                </Grid>
            </Grid>
        </SplitView.Content>
    </SplitView>

    <!--  LightBox Overlay  -->
    <Grid
        x:Name="LightBoxOverlay"
        Canvas.ZIndex="100"
        Background="#E0000000"
        PointerPressed="LightBoxOverlay_PointerPressed"
        Visibility="Collapsed">
        <Button
            x:Name="LightBoxCloseButton"
            Width="48"
            Height="48"
            Margin="24"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#30FFFFFF"
            BorderThickness="0"
            Click="LightBoxClose_Click"
            CornerRadius="24">
            <FontIcon
                FontSize="20"
                Foreground="White"
                Glyph="&#xE711;" />
        </Button>
        <ProgressRing
            x:Name="LightBoxLoading"
            Width="64"
            Height="64"
            Foreground="White"
            IsActive="False"
            Visibility="Collapsed" />
        <Image
            x:Name="LightBoxImage"
            Margin="60"
            Stretch="Uniform" />
    </Grid>
    </Grid>
</Page>
